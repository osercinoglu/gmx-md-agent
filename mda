#!/usr/bin/env bash
# mda — thin host wrapper around `docker run` for the gmx-md-agent image.
# Runs the agent on the current folder (mounted at /work), auto-adding GPU access
# when the nvidia container runtime is available and mounting any credentials you
# already have. Examples:
#   ./mda local  --prod-mdp prod.mdp --total-ns 500
#   ./mda cloud  --prod-mdp prod.mdp --gpu-names RTX_4090
#   ./mda extend --from md_0_250ns --to-ns 750 --where cloud
#   MDAGENT_DETACH=1 ./mda cloud --prod-mdp prod.mdp   # detach (long cloud runs)
#
# Env overrides: MDAGENT_IMAGE (default gmx-md-agent), MDAGENT_WORK (default $PWD),
#   MDAGENT_GPUS=1 force --gpus all, MDAGENT_GPUS=0 disable, MDAGENT_DETACH=1.
set -euo pipefail
IMAGE="${MDAGENT_IMAGE:-gmx-md-agent}"
WORK="${MDAGENT_WORK:-$PWD}"

# GPU passthrough: explicit env wins; else auto-detect. Only the `local` subcommand
# uses THIS machine's GPU — cloud/extend(--where cloud)/status/follow/teardown just
# orchestrate (GROMACS runs on the rented node), so requesting --gpus there is
# pointless and can hard-fail on hosts whose Docker GPU runtime/CDI isn't set up
# (e.g. "AMD CDI spec not found"). Force on with MDAGENT_GPUS=1, off with =0.
subcmd="${1:-}"
gpu_args=()
case "${MDAGENT_GPUS:-auto}" in
  1) gpu_args=(--gpus all) ;;
  0) gpu_args=() ;;
  *) if [ "$subcmd" = "local" ] && docker info 2>/dev/null | grep -qiE 'Runtimes:.*nvidia|nvidia'; then
       gpu_args=(--gpus all)
     fi ;;
esac

# Mount the working folder + any credentials/state that exist on the host.
# NOTE: we deliberately do NOT mount the host ~/.ssh — SkyPilot generates and owns
# its own key inside the container (/root/.ssh). A bind-mounted host ~/.ssh arrives
# owned by your uid, and the ssh client then rejects it ("Bad owner or permissions
# on /root/.ssh/config"), breaking provisioning.
mounts=(-v "$WORK":/work)
for pair in \
  "$HOME/.config/vastai:/root/.config/vastai" \
  "$HOME/.pushover:/root/.pushover" \
  "$HOME/.sky:/root/.sky"; do
  [ -e "${pair%%:*}" ] && mounts+=(-v "$pair")
done

# Forward run-tuning env vars into the container when set on the host, e.g.
#   VAST_MAX_DPH=0.40 ./mda cloud ...   (per-GPU price ceiling, patch-enforced)
# VAST_MAX_DPH: hard $/hr ceiling on the chosen Vast offer (the baked-in provisioner
#               patch honors it); MAX_HOURLY: offer-browser cost cap (0=no cap);
# KEEPALIVE_MAXH: hours a node holds itself up awaiting a verified pull;
# GMX_MAX_SM_MAJOR: max GPU compute-capability major the node GROMACS supports (9 for 2024.2).
env_args=()
for v in VAST_MAX_DPH MAX_HOURLY KEEPALIVE_MAXH GMX_MAX_SM_MAJOR GMX_CONDA_SPEC VAST_API_KEY PUSHOVER_TOKEN PUSHOVER_USER; do
  [ -n "${!v:-}" ] && env_args+=(-e "$v=${!v}")
done

mode=(--rm -it)
[ "${MDAGENT_DETACH:-0}" = "1" ] && mode=(--rm -d)

exec docker run "${mode[@]}" "${gpu_args[@]}" "${env_args[@]}" "${mounts[@]}" "$IMAGE" "$@"
