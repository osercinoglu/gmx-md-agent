title                   = NVT equilibration (independent replica)
define                  = -DPOSRES
; Run parameters
integrator              = md
nsteps                  = 500000           ; 1 ns at dt=0.002
dt                      = 0.002
; Output control
nstxout                 = 5000
nstvout                 = 5000
nstenergy               = 5000
nstlog                  = 5000
; Bond parameters
continuation            = no
constraint_algorithm    = lincs
constraints             = h-bonds
lincs_iter              = 1
lincs_order             = 4
; Nonbonded settings
cutoff-scheme           = Verlet
ns_type                 = grid
nstlist                 = 10
rcoulomb                = 1.0
rvdw                    = 1.0
DispCorr                = EnerPres
; Electrostatics
coulombtype             = PME
pme_order               = 4
fourierspacing          = 0.16
; Temperature coupling
tcoupl                  = V-rescale
tc-grps                 = Protein Non-Protein
tau_t                   = 0.1     0.1
ref_t                   = 310     310
; Pressure coupling off in NVT
pcoupl                  = no
; PBC
pbc                     = xyz
; Velocity generation - RANDOM seed for independent replica
gen_vel                 = yes
gen_temp                = 310
gen_seed                = -1               ; -1 = random seed; THIS is what makes the replica independent
